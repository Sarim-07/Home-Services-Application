    JPanel buildCustomers() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(BG);
        panel.setBorder(new EmptyBorder(24, 28, 24, 28));
        JLabel title = lbl("Customer Management", 22, true, TEXT_DARK);
        String[] cols = new String[]{"ID", "Name", "Email", "Phone", "Address", "Bookings"};
        DefaultTableModel model = new DefaultTableModel(cols, 0) {
            public boolean isCellEditable(int r, int c) {
                return false;
            }
        };

        for(Customer c : this.db.getCustomers()) {
            model.addRow(new Object[]{c.getUserId(), c.getName(), c.getEmail(), c.getPhone(), c.getAddress(), c.getBookingHistory().size()});
        }

        JTable table = this.styledTable(model);
        table.getColumnModel().getColumn(0).setPreferredWidth(70);
        table.getColumnModel().getColumn(5).setPreferredWidth(80);
        JButton deleteBtn = this.dangerButton("Delete Customer");
        deleteBtn.addActionListener((e) -> {
            int row = table.getSelectedRow();
            if (row < 0) {
                this.warn("Select a customer first.");
            } else {
                String id = model.getValueAt(row, 0).toString();
                Customer c = this.db.getCustomerById(id);
                if (c != null) {
                    int confirm = JOptionPane.showConfirmDialog(this, "Delete customer \"" + c.getName() + "\" and all their bookings?", "Confirm Delete", 0, 2);
                    if (confirm == 0) {
                        this.admin.forceCancel((Booking)null);
                        this.db.removeCustomer(c);
                        model.removeRow(row);
                        this.info("Customer deleted successfully.");
                    }

                }
            }
        });
        JLabel countLbl = lbl(this.db.getCustomers().size() + " customers registered", 13, false, TEXT_MUTED);
        JPanel hdr = new JPanel(new BorderLayout());
        hdr.setBackground(BG);
        hdr.setBorder(new EmptyBorder(0, 0, 12, 0));
        JPanel hdrLeft = new JPanel(new FlowLayout(0, 0, 0));
        hdrLeft.setBackground(BG);
        hdrLeft.add(title);
        hdrLeft.add(Box.createHorizontalStrut(16));
        hdrLeft.add(countLbl);
        hdr.add(hdrLeft, "West");
        hdr.add(deleteBtn, "East");
        panel.add(hdr, "North");
        panel.add(new JScrollPane(table), "Center");
        return panel;
    }

    JPanel buildProviders() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(BG);
        panel.setBorder(new EmptyBorder(24, 28, 24, 28));
        JLabel title = lbl("Provider Management", 22, true, TEXT_DARK);
        String[] cols = new String[]{"ID", "Name", "Specialty", "Phone", "Rating", "Jobs", "Status"};
