        };

        for(ServiceProvider p : this.db.getProviders()) {
            model.addRow(new Object[]{p.getUserId(), p.getName(), p.getSpecialty(), p.getPhone(), p.getTotalRatings() > 0 ? String.format("%.1f ★", p.getRating()) : "N/A", p.getAssignedBookings().size(), p.isAvailable() ? "Active" : "Suspended"});
        }

        JTable table = this.styledTable(model);
        table.getColumnModel().getColumn(6).setCellRenderer((t, v, sel, foc, row, col) -> {
            boolean active = "Active".equals(v);
            JLabel l = new JLabel(" " + v + " ");
            l.setOpaque(true);
            l.setBackground(active ? new Color(220, 252, 231) : new Color(254, 226, 226));
            l.setForeground(active ? new Color(22, 101, 52) : new Color(153, 27, 27));
            l.setFont(new Font("Segoe UI", 1, 11));
            l.setBorder(new EmptyBorder(3, 8, 3, 8));
            return l;
        });
        JButton suspendBtn = new JButton("Suspend Provider");
        suspendBtn.setBackground(new Color(254, 243, 199));
        suspendBtn.setForeground(new Color(146, 64, 14));
        suspendBtn.setFont(new Font("Segoe UI", 1, 13));
        suspendBtn.setFocusPainted(false);
        suspendBtn.setBorder(BorderFactory.createCompoundBorder(new LineBorder(new Color(253, 230, 138), 1, true), new EmptyBorder(7, 16, 7, 16)));
        suspendBtn.setCursor(new Cursor(12));
        JButton reinstateBtn = this.primaryButton("Reinstate");
        suspendBtn.addActionListener((e) -> {
            int row = table.getSelectedRow();
            if (row < 0) {
                this.warn("Select a provider first.");
            } else {
                ServiceProvider p = (ServiceProvider)this.db.getProviders().get(row);
                this.admin.suspendProvider(p);
                this.db.save();
                model.setValueAt("Suspended", row, 6);
                this.info(p.getName() + " has been suspended.");
            }
        });
        reinstateBtn.addActionListener((e) -> {
            int row = table.getSelectedRow();
            if (row < 0) {
                this.warn("Select a provider first.");
            } else {
                ServiceProvider p = (ServiceProvider)this.db.getProviders().get(row);
                this.admin.reinstateProvider(p);
                this.db.save();
                model.setValueAt("Active", row, 6);
                this.info(p.getName() + " has been reinstated.");
            }
        });
        JPanel hdr = new JPanel(new BorderLayout());
        hdr.setBackground(BG);
        hdr.setBorder(new EmptyBorder(0, 0, 12, 0));
