    JPanel buildBookings() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(BG);
        panel.setBorder(new EmptyBorder(24, 28, 24, 28));
        JLabel title = lbl("All Bookings", 22, true, TEXT_DARK);
        String[] cols = new String[]{"ID", "Customer", "Provider", "Service", "Scheduled", "Price", "Status"};
        DefaultTableModel model = new DefaultTableModel(cols, 0) {
            public boolean isCellEditable(int r, int c) {
                return false;
            }
        };
        List<Booking> all = this.db.getAllBookings();

        for(Booking b : all) {
            model.addRow(new Object[]{b.getBookingId(), b.getCustomerName(), b.getProviderName(), b.getServiceName(), b.getFormattedDateTime(), b.getFormattedPrice(), b.getStatus()});
        }

        JTable table = this.styledTable(model);
        table.getColumnModel().getColumn(6).setCellRenderer((t, v, sel, foc, row, col) -> this.statusBadge(v.toString()));
        JButton cancelBtn = this.dangerButton("Force Cancel Booking");
        cancelBtn.addActionListener((e) -> {
            int row = table.getSelectedRow();
            if (row < 0) {
                this.warn("Select a booking to cancel.");
            } else {
                Booking b = (Booking)all.get(row);
                if (!b.getStatus().equals("Cancelled") && !b.getStatus().equals("Completed")) {
                    this.admin.forceCancel(b);
                    this.db.save();
                    model.setValueAt("Cancelled", row, 6);
                    this.info("Booking " + b.getBookingId() + " force-cancelled.");
                } else {
                    this.warn("This booking cannot be cancelled (already " + b.getStatus() + ").");
                }
            }
        });
        String[] statusOpts = new String[]{"All Statuses", "Pending", "Accepted", "Completed", "Rejected", "Cancelled"};
        JComboBox<String> statusFilter = new JComboBox(statusOpts);
        statusFilter.setFont(new Font("Segoe UI", 0, 13));
        statusFilter.setPreferredSize(new Dimension(160, 34));
        statusFilter.addActionListener((e) -> {
            String sel = (String)statusFilter.getSelectedItem();
            model.setRowCount(0);

            for(Booking b : all) {
                if ("All Statuses".equals(sel) || b.getStatus().equals(sel)) {
                    model.addRow(new Object[]{b.getBookingId(), b.getCustomerName(), b.getProviderName(), b.getServiceName(), b.getFormattedDateTime(), b.getFormattedPrice(), b.getStatus()});
                }
            }

        });
        JPanel hdr = new JPanel(new BorderLayout());
        hdr.setBackground(BG);
        hdr.setBorder(new EmptyBorder(0, 0, 12, 0));
        JPanel hdrLeft = new JPanel(new FlowLayout(0, 8, 0));
        hdrLeft.setBackground(BG);
        hdrLeft.add(title);
        hdrLeft.add(lbl("Filter:", 13, false, TEXT_MUTED));
        hdrLeft.add(statusFilter);
        hdr.add(hdrLeft, "West");
        hdr.add(cancelBtn, "East");
        panel.add(hdr, "North");
        panel.add(new JScrollPane(table), "Center");
        return panel;
    }

    JPanel buildAnalytics() {
        JPanel panel = new JPanel();
        panel.setLayout(new BoxLayout(panel, 1));
        panel.setBackground(BG);
        panel.setBorder(new EmptyBorder(28, 28, 28, 28));
        JLabel title = lbl("Analytics & Revenue", 22, true, TEXT_DARK);
        JLabel sub = lbl("Financial performance and provider rankings", 13, false, TEXT_MUTED);
        title.setAlignmentX(0.0F);
        sub.setAlignmentX(0.0F);
        JPanel revRow = new JPanel(new GridLayout(1, 4, 12, 0));
        revRow.setBackground(BG);
        revRow.setAlignmentX(0.0F);
        revRow.setMaximumSize(new Dimension(Integer.MAX_VALUE, 100));
        Map<String, Double> revByCat = this.db.revenueByCategory();
        String[] catNames = new String[]{"Plumbing", "Electrical", "Cleaning", "AC Repair"};
        Color[] catClrs = new Color[]{PRIMARY, SUCCESS, WARNING, DANGER};

        for(int i = 0; i < catNames.length; ++i) {
            double rev = (Double)revByCat.getOrDefault(catNames[i], (double)0.0F);
            revRow.add(this.kpiCard(catNames[i], String.format("PKR %,.0f", rev), new Color(239 - i * 10, 246 - i * 5, 255), catClrs[i]));
        }

        String[] catLabels = (String[])revByCat.keySet().toArray(new String[0]);
        int[] catVals = revByCat.values().stream().mapToInt(Double::intValue).toArray();
        JPanel revenueChart = this.buildBarChart("Revenue by Category (PKR)", catLabels, catVals, CHART_COLORS);
        revenueChart.setAlignmentX(0.0F);
        revenueChart.setMaximumSize(new Dimension(Integer.MAX_VALUE, 300));
        List<ServiceProvider> providers = new ArrayList(this.db.getProviders());
        providers.sort((a, b) -> Integer.compare(b.getAssignedBookings().size(), a.getAssignedBookings().size()));
        String[] provNames = (String[])providers.stream().map(User::getName).toArray((x$0) -> new String[x$0]);
        int[] provJobs = providers.stream().mapToInt((px) -> px.getAssignedBookings().size()).toArray();
        JPanel provChart = this.buildBarChart("Provider Job Count", provNames, provJobs, CHART_COLORS);
        provChart.setAlignmentX(0.0F);
        provChart.setMaximumSize(new Dimension(Integer.MAX_VALUE, 280));
        JLabel ratTitle = lbl("Provider Ratings", 16, true, TEXT_DARK);
        ratTitle.setAlignmentX(0.0F);
        String[] ratCols = new String[]{"Provider", "Specialty", "Rating", "Total Reviews", "Jobs Completed"};
        DefaultTableModel ratModel = new DefaultTableModel(ratCols, 0) {
            public boolean isCellEditable(int r, int c) {
                return false;
            }
        };

        for(ServiceProvider p : providers) {
            long completed = p.getAssignedBookings().stream().filter((b) -> b.getStatus().equals("Completed")).count();
            ratModel.addRow(new Object[]{p.getName(), p.getSpecialty(), p.getTotalRatings() > 0 ? String.format("%.1f ★", p.getRating()) : "No ratings", p.getTotalRatings(), completed});
        }

        JTable ratTable = this.styledTable(ratModel);
        ratTable.setPreferredScrollableViewportSize(new Dimension(0, 120));
        JScrollPane ratScroll = new JScrollPane(ratTable);
        ratScroll.setBorder(new LineBorder(BORDER, 1, true));
        ratScroll.setAlignmentX(0.0F);
        ratScroll.setMaximumSize(new Dimension(Integer.MAX_VALUE, 160));
        panel.add(title);
        panel.add(Box.createVerticalStrut(2));
        panel.add(sub);
        panel.add(Box.createVerticalStrut(16));
        panel.add(revRow);
        panel.add(Box.createVerticalStrut(20));
        panel.add(revenueChart);
        panel.add(Box.createVerticalStrut(20));
        panel.add(provChart);
        panel.add(Box.createVerticalStrut(16));
        panel.add(ratTitle);
        panel.add(Box.createVerticalStrut(8));
        panel.add(ratScroll);
        JScrollPane outerScroll = new JScrollPane(panel);
        outerScroll.setBorder(BorderFactory.createEmptyBorder());
        outerScroll.getVerticalScrollBar().setUnitIncrement(16);
        JPanel wrapper = new JPanel(new BorderLayout());
        wrapper.setBackground(BG);
        wrapper.add(outerScroll, "Center");
        return wrapper;
    }

    JPanel buildBarChart(String chartTitle, final String[] labels, final int[] values, final Color[] colors) {
        JPanel wrapper = new JPanel(new BorderLayout());
        wrapper.setBackground(CARD_BG);
        wrapper.setBorder(BorderFactory.createCompoundBorder(new LineBorder(BORDER, 1, true), new EmptyBorder(16, 20, 16, 20)));
        JLabel tl = lbl(chartTitle, 14, true, TEXT_DARK);
        tl.setBorder(new EmptyBorder(0, 0, 10, 0));
        JPanel canvas = new JPanel() {
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2 = (Graphics2D)g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_ON);
                int W = this.getWidth();
                int H = this.getHeight();
                int padL = 55;
                int padR = 20;
                int padT = 10;
                int padB = 50;
                int chartW = W - padL - padR;
                int chartH = H - padT - padB;
                if (chartH > 0 && chartW > 0 && labels.length != 0) {
                    int maxVal = 0;

                    for(int v : values) {
                        maxVal = Math.max(maxVal, v);
                    }

                    if (maxVal == 0) {
                        maxVal = 1;
                    }

                    g2.setStroke(new BasicStroke(0.5F));
                    g2.setFont(new Font("Segoe UI", 0, 10));
                    int gridLines = 4;

                    for(int i = 0; i <= gridLines; ++i) {
                        int y = padT + chartH - i * chartH / gridLines;
                        g2.setColor(AdminDashboard.BORDER);
                        g2.drawLine(padL, y, padL + chartW, y);
                        g2.setColor(AdminDashboard.TEXT_MUTED);
                        String gridLbl = String.valueOf(i * maxVal / gridLines);
                        g2.drawString(gridLbl, padL - g2.getFontMetrics().stringWidth(gridLbl) - 6, y + 4);
                    }

                    int n = labels.length;
                    int gap = Math.max(6, chartW / (n * 6));
                    int barW = (chartW - gap * (n + 1)) / n;
                    if (barW < 4) {
                        barW = 4;
                    }

                    for(int i = 0; i < n; ++i) {
                        int barH = (int)((double)values[i] / (double)maxVal * (double)chartH);
                        int x = padL + gap + i * (barW + gap);
                        int y = padT + chartH - barH;
                        g2.setColor(colors[i % colors.length]);
                        g2.fillRoundRect(x, y, barW, barH, 6, 6);
                        g2.setColor(AdminDashboard.TEXT_DARK);
                        g2.setFont(new Font("Segoe UI", 1, 10));
                        String valStr = String.valueOf(values[i]);
                        int valX = x + (barW - g2.getFontMetrics().stringWidth(valStr)) / 2;
                        if (y - 4 > padT) {
                            g2.drawString(valStr, valX, y - 4);
                        }

                        g2.setColor(AdminDashboard.TEXT_MUTED);
                        g2.setFont(new Font("Segoe UI", 0, 10));
                        String lb = labels[i];
                        String[] words = lb.split(" ");
                        int lblY = padT + chartH + 16;
                        if (words.length > 1 && barW < 80) {
                            for(String w : words) {
                                int lx = x + (barW - g2.getFontMetrics().stringWidth(w)) / 2;
                                g2.drawString(w, lx, lblY);
                                lblY += 12;
                            }
                        } else {
                            int lx = x + (barW - g2.getFontMetrics().stringWidth(lb)) / 2;
                            g2.drawString(lb, lx, lblY);
                        }
                    }

                    g2.setColor(AdminDashboard.BORDER);
                    g2.setStroke(new BasicStroke(1.0F));
                    g2.drawLine(padL, padT, padL, padT + chartH);
                }
            }
        };
        canvas.setBackground(CARD_BG);
        canvas.setPreferredSize(new Dimension(0, 220));
        wrapper.add(tl, "North");
        wrapper.add(canvas, "Center");
        return wrapper;
    }

    JPanel buildDonutChart(String chartTitle, final String[] labels, final int[] values, final Color[] colors) {
        JPanel wrapper = new JPanel(new BorderLayout(0, 0));
        wrapper.setBackground(CARD_BG);
        wrapper.setBorder(BorderFactory.createCompoundBorder(new LineBorder(BORDER, 1, true), new EmptyBorder(16, 20, 16, 20)));
        JLabel tl = lbl(chartTitle, 14, true, TEXT_DARK);
        tl.setBorder(new EmptyBorder(0, 0, 10, 0));
        JPanel canvas = new JPanel() {
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2 = (Graphics2D)g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                int W = this.getWidth();
                int H = this.getHeight();
                int total = 0;

                for(int v : values) {
                    total += v;
                }

                if (total == 0) {
                    g2.setColor(AdminDashboard.TEXT_MUTED);
                    g2.setFont(new Font("Segoe UI", 0, 13));
                    g2.drawString("No data yet", W / 2 - 35, H / 2);
                } else {
                    int dia = Math.min(W / 2 - 20, H - 30);
                    int ox = (W / 2 - dia) / 2;
                    int oy = (H - dia) / 2;
                    int hole = (int)((double)dia * 0.55);
                    int hx = ox + (dia - hole) / 2;
                    int hy = oy + (dia - hole) / 2;
                    double angle = (double)-90.0F;

                    for(int i = 0; i < values.length; ++i) {
                        double sweep = (double)values[i] / (double)total * (double)360.0F;
                        g2.setColor(colors[i % colors.length]);
                        g2.fillArc(ox, oy, dia, dia, (int)angle, (int)sweep);
                        angle += sweep;
                    }

                    g2.setColor(AdminDashboard.CARD_BG);
                    g2.fillOval(hx, hy, hole, hole);
                    g2.setColor(AdminDashboard.TEXT_DARK);
                    g2.setFont(new Font("Segoe UI", 1, 20));
                    String tot = String.valueOf(total);
                    FontMetrics fm = g2.getFontMetrics();
                    g2.drawString(tot, W / 4 - fm.stringWidth(tot) / 2, H / 2 + 7);
                    g2.setColor(AdminDashboard.TEXT_MUTED);
                    g2.setFont(new Font("Segoe UI", 0, 10));
                    g2.drawString("total", W / 4 - 10, H / 2 + 20);
                    int legX = W / 2 + 10;
                    int legY = H / 2 - labels.length * 22 / 2;
                    g2.setFont(new Font("Segoe UI", 0, 11));

                    for(int i = 0; i < labels.length; ++i) {
                        g2.setColor(colors[i % colors.length]);
                        g2.fillRoundRect(legX, legY + i * 22, 12, 12, 4, 4);
                        g2.setColor(AdminDashboard.TEXT_DARK);
                        int var10000 = values[i];
                        String pct = var10000 + " (" + (total > 0 ? values[i] * 100 / total : 0) + "%)";
                        g2.drawString(labels[i] + ": " + pct, legX + 18, legY + i * 22 + 11);
                    }

                }
            }
        };
        canvas.setBackground(CARD_BG);
        canvas.setPreferredSize(new Dimension(0, 220));
        wrapper.add(tl, "North");
        wrapper.add(canvas, "Center");
        return wrapper;
    }

    JPanel kpiCard(String label, String value, Color bg, Color accent) {
        JPanel p = new JPanel();
        p.setLayout(new BoxLayout(p, 1));
        p.setBackground(bg);
        p.setBorder(BorderFactory.createCompoundBorder(new LineBorder(accent.brighter(), 1, true), new EmptyBorder(14, 16, 14, 16)));
        JLabel vl = lbl(value, 26, true, accent);
        vl.setAlignmentX(0.0F);
        JLabel ll = lbl(label, 12, false, TEXT_MUTED);
        ll.setAlignmentX(0.0F);
        p.add(vl);
        p.add(Box.createVerticalStrut(4));
        p.add(ll);
        return p;
    }

    JPanel miniBookingRow(Booking b) {
        JPanel row = new JPanel(new BorderLayout(10, 0));
        row.setBackground(CARD_BG);
        row.setBorder(BorderFactory.createCompoundBorder(new LineBorder(BORDER, 1, true), new EmptyBorder(10, 14, 10, 14)));
        row.setMaximumSize(new Dimension(Integer.MAX_VALUE, 56));
        row.setAlignmentX(0.0F);
        JPanel info = new JPanel();
        info.setLayout(new BoxLayout(info, 1));
        info.setBackground(CARD_BG);
        info.add(lbl(b.getServiceName() + " — " + b.getCustomerName(), 13, true, TEXT_DARK));
        info.add(lbl(b.getProviderName() + "  ·  " + b.getFormattedPrice(), 11, false, TEXT_MUTED));
        row.add(info, "Center");
        row.add(this.statusBadge(b.getStatus()), "East");
        return row;
    }

    JTable styledTable(DefaultTableModel model) {
        JTable t = new JTable(model);
        t.setRowHeight(36);
        t.setFont(new Font("Segoe UI", 0, 13));
        t.getTableHeader().setFont(new Font("Segoe UI", 1, 13));
        t.getTableHeader().setBackground(new Color(241, 245, 249));
        t.getTableHeader().setForeground(TEXT_DARK);
        t.setGridColor(BORDER);
        t.setSelectionBackground(new Color(239, 246, 255));
        t.setShowVerticalLines(false);
        t.setIntercellSpacing(new Dimension(0, 1));
        return t;
    }

    JLabel statusBadge(String status) {
        Color bg;
        Color fg;
        switch (status) {
            case "Accepted":
                bg = new Color(220, 252, 231);
                fg = new Color(22, 101, 52);
                break;
            case "Pending":
                bg = new Color(254, 243, 199);
                fg = new Color(146, 64, 14);
                break;
            case "Rejected":
                bg = new Color(254, 226, 226);
                fg = new Color(153, 27, 27);
                break;
            case "Completed":
                bg = new Color(219, 234, 254);
                fg = new Color(30, 64, 175);
                break;
            default:
                bg = new Color(241, 245, 249);
                fg = new Color(71, 85, 105);
        }

        JLabel l = new JLabel(" " + status + " ");
        l.setOpaque(true);
        l.setBackground(bg);
        l.setForeground(fg);
        l.setFont(new Font("Segoe UI", 1, 11));
        l.setBorder(new EmptyBorder(3, 8, 3, 8));
        return l;
    }

    static JLabel lbl(String text, int size, boolean bold, Color color) {
        JLabel l = new JLabel(text);
        l.setFont(new Font("Segoe UI", bold ? 1 : 0, size));
        l.setForeground(color);
        return l;
    }

    JButton primaryButton(String text) {
        final JButton btn = new JButton(text);
        btn.setBackground(PRIMARY);
        btn.setForeground(Color.WHITE);
        btn.setFont(new Font("Segoe UI", 1, 13));
        btn.setBorder(BorderFactory.createCompoundBorder(new LineBorder(PRIMARY_DARK, 1, true), new EmptyBorder(7, 16, 7, 16)));
        btn.setFocusPainted(false);
        btn.setCursor(new Cursor(12));
        btn.addMouseListener(new MouseAdapter() {
            public void mouseEntered(MouseEvent e) {
                btn.setBackground(AdminDashboard.PRIMARY_DARK);
            }

            public void mouseExited(MouseEvent e) {
                btn.setBackground(AdminDashboard.PRIMARY);
            }
        });
        return btn;
    }

    JButton dangerButton(String text) {
        JButton btn = new JButton(text);
        btn.setBackground(new Color(254, 226, 226));
        btn.setForeground(DANGER);
        btn.setFont(new Font("Segoe UI", 1, 13));
        btn.setBorder(BorderFactory.createCompoundBorder(new LineBorder(new Color(252, 165, 165), 1, true), new EmptyBorder(7, 16, 7, 16)));
        btn.setFocusPainted(false);
        btn.setCursor(new Cursor(12));
        return btn;
    }

    JButton navBtn(String text, boolean active) {
        final JButton btn = new JButton(text);
        btn.setFont(new Font("Segoe UI", 0, 13));
        btn.setForeground(active ? Color.WHITE : new Color(148, 163, 184));
        btn.setBackground(active ? SIDEBAR_ACTIVE : SIDEBAR_BG);
        btn.setBorder(new EmptyBorder(10, 20, 10, 20));
        btn.setFocusPainted(false);
        btn.setHorizontalAlignment(2);
        btn.setCursor(new Cursor(12));
        btn.setMaximumSize(new Dimension(Integer.MAX_VALUE, 42));
        btn.setAlignmentX(0.0F);
        btn.addMouseListener(new MouseAdapter() {
            public void mouseEntered(MouseEvent e) {
                if (!btn.getBackground().equals(AdminDashboard.SIDEBAR_ACTIVE)) {
                    btn.setBackground(new Color(30, 41, 59));
                    btn.setForeground(Color.WHITE);
                }

            }

            public void mouseExited(MouseEvent e) {
                if (!btn.getBackground().equals(AdminDashboard.SIDEBAR_ACTIVE)) {
                    btn.setBackground(AdminDashboard.SIDEBAR_BG);
                    btn.setForeground(new Color(148, 163, 184));
                }

            }
        });
        return btn;
    }

    void warn(String msg) {
        JOptionPane.showMessageDialog(this, msg, "Warning", 2);
    }

    void info(String msg) {
        JOptionPane.showMessageDialog(this, msg, "Done", 1);
    }

    static {
        CARD_BG = Color.WHITE;
        BORDER = new Color(226, 232, 240);
        TEXT_DARK = new Color(15, 23, 42);
        TEXT_MUTED = new Color(100, 116, 139);
        SIDEBAR_BG = new Color(15, 23, 42);
        SIDEBAR_ACTIVE = new Color(37, 99, 235);
        CHART_COLORS = new Color[]{new Color(37, 99, 235), new Color(22, 163, 74), new Color(217, 119, 6), new Color(220, 38, 38), new Color(126, 34, 206)};
    }
}
