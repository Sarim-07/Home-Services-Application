    void refreshScreen(String screen, int idx) {
        this.contentPanel.removeAll();
        this.contentPanel.add(this.buildOverview(), "OVERVIEW");
        this.contentPanel.add(this.buildCustomers(), "CUSTOMERS");
        this.contentPanel.add(this.buildProviders(), "PROVIDERS");
        this.contentPanel.add(this.buildBookings(), "BOOKINGS");
        this.contentPanel.add(this.buildAnalytics(), "ANALYTICS");
        this.contentCL.show(this.contentPanel, screen);

        for(int j = 0; j < this.navBtns.length - 1; ++j) {
            this.navBtns[j].setBackground(j == idx ? SIDEBAR_ACTIVE : SIDEBAR_BG);
            this.navBtns[j].setForeground(j == idx ? Color.WHITE : new Color(148, 163, 184));
        }

    }

