package homeservicessystem;

import java.io.BufferedReader;
import java.io.File;
import java.io.FileReader;
import java.io.FileWriter;
import java.io.IOException;
import java.io.PrintWriter;
import java.time.LocalDateTime;
import java.util.List;

public class DataPersistence {
    private static final String CUSTOMERS_FILE = "customers.csv";
    private static final String PROVIDERS_FILE = "providers.csv";
    private static final String BOOKINGS_FILE = "bookings.csv";
    private static final String SEP = "|";
    private static final String SEP_REGEX = "\\|";

    public DataPersistence() {
    }

    public static void saveAll(DataStore db) {
        saveCustomers(db.getCustomers());
        saveProviders(db.getProviders());
        saveBookings(db.getAllBookings());
    }

    private static void saveCustomers(List<Customer> customers) {
        try (PrintWriter pw = new PrintWriter(new FileWriter("customers.csv"))) {
            pw.println("userId|name|email|password|phone|address");

            for(Customer c : customers) {
                pw.println(String.join("|", c.getUserId(), c.getName(), c.getEmail(), c.getPassword(), c.getPhone(), c.getAddress()));
            }
        } catch (IOException e) {
            System.err.println("[DataPersistence] Failed to save customers: " + e.getMessage());
        }

    }

    private static void saveProviders(List<ServiceProvider> providers) {
        try (PrintWriter pw = new PrintWriter(new FileWriter("providers.csv"))) {
            pw.println("userId|name|email|password|phone|specialty|rating|totalRatings|isAvailable");

            for(ServiceProvider p : providers) {
                pw.println(String.join("|", p.getUserId(), p.getName(), p.getEmail(), p.getPassword(), p.getPhone(), p.getSpecialty(), String.valueOf(p.getRating()), String.valueOf(p.getTotalRatings()), String.valueOf(p.isAvailable())));
            }
        } catch (IOException e) {
            System.err.println("[DataPersistence] Failed to save providers: " + e.getMessage());
        }

    }

    private static void saveBookings(List<Booking> bookings) {
        try (PrintWriter pw = new PrintWriter(new FileWriter("bookings.csv"))) {
            pw.println("bookingId|customerId|providerId|serviceId|dateTime|status|notes|rating|customerName|providerName|serviceName|totalPrice");

            for(Booking b : bookings) {
                pw.println(String.join("|", b.getBookingId(), b.getCustomerId(), b.getProviderId(), b.getServiceId(), b.getBookingDateTime().toString(), b.getStatus(), b.getNotes().replace("|", " "), String.valueOf(b.getRating()), b.getCustomerName(), b.getProviderName(), b.getServiceName(), String.valueOf(b.getTotalPrice())));
            }
        } catch (IOException e) {
            System.err.println("[DataPersistence] Failed to save bookings: " + e.getMessage());
        }

    }

    public static boolean loadAll(DataStore db) {
        File cf = new File("customers.csv");
        File pf = new File("providers.csv");
        File bf = new File("bookings.csv");
        if (!cf.exists() && !pf.exists() && !bf.exists()) {
            return false;
        } else {
            loadCustomers(db, cf);
            loadProviders(db, pf);
            loadBookings(db, bf);
            return true;
        }
    }

    private static void loadCustomers(DataStore db, File file) {
        if (file.exists()) {
            try (BufferedReader br = new BufferedReader(new FileReader(file))) {
                String line = br.readLine();

                while((line = br.readLine()) != null) {
                    if (!line.trim().isEmpty()) {
                        String[] f = line.split("\\|", -1);
                        if (f.length >= 6) {
                            Customer c = new Customer(f[0], f[1], f[2], f[3], f[4], f[5]);
                            db.getCustomers().add(c);
                        }
                    }
                }
            } catch (IOException e) {
                System.err.println("[DataPersistence] Failed to load customers: " + e.getMessage());
            }

        }
    }

    private static void loadProviders(DataStore db, File file) {
        if (file.exists()) {
            try (BufferedReader br = new BufferedReader(new FileReader(file))) {
                String line = br.readLine();

                while((line = br.readLine()) != null) {
                    if (!line.trim().isEmpty()) {
                        String[] f = line.split("\\|", -1);
                        if (f.length >= 9) {
                            ServiceProvider p = new ServiceProvider(f[0], f[1], f[2], f[3], f[4], f[5]);
                            int totalRatings = Integer.parseInt(f[7]);
                            double savedRating = Double.parseDouble(f[6]);
                            p.restoreRating(savedRating, totalRatings);
                            p.setAvailable(Boolean.parseBoolean(f[8]));
                            db.getProviders().add(p);
                        }
                    }
                }
            } catch (IOException e) {
                System.err.println("[DataPersistence] Failed to load providers: " + e.getMessage());
            }

        }
    }

    private static void loadBookings(DataStore db, File file) {
        if (file.exists()) {
            try (BufferedReader br = new BufferedReader(new FileReader(file))) {
                String line = br.readLine();

                while((line = br.readLine()) != null) {
                    if (!line.trim().isEmpty()) {
                        String[] f = line.split("\\|", -1);
                        if (f.length >= 12) {
                            LocalDateTime dt = LocalDateTime.parse(f[4]);
                            Booking b = new Booking(f[0], f[1], f[2], f[3], dt, f[6], f[8], f[9], f[10], Double.parseDouble(f[11]));
                            b.setStatus(f[5]);
                            b.setRating(Integer.parseInt(f[7]));
                            db.getAllBookings().add(b);

                            for(Customer c : db.getCustomers()) {
                                if (c.getUserId().equals(f[1])) {
                                    c.addBooking(b);
                                    break;
                                }
                            }

                            for(ServiceProvider p : db.getProviders()) {
                                if (p.getUserId().equals(f[2])) {
                                    p.addBooking(b);
                                    break;
                                }
                            }
                        }
                    }
                }
            } catch (IOException e) {
                System.err.println("[DataPersistence] Failed to load bookings: " + e.getMessage());
            }

        }
    }

    public static String getSaveLocation() {
        return (new File("customers.csv")).getAbsolutePath().replace("customers.csv", "");
    }
}
