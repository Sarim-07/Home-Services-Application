            if (!name.isEmpty() && !email.isEmpty() && !pass.isEmpty() && !phone.isEmpty() && !extra.isEmpty()) {
                if (!email.contains("@")) {
                    this.showMessage("Please enter a valid email address.", "Invalid Email", 2);
                } else if (this.db.emailExists(email)) {
                    this.showMessage("This email is already registered.", "Email Taken", 0);
