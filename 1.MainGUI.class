    JPanel buildCustomerDashboard(Customer customer) {
        JPanel root = new JPanel(new BorderLayout());
        JPanel sidebar = this.buildSidebar(customer.getName(), "Customer", new String[]{"\ud83c\udfe0  Overview", "\ud83d\udd0d  Book Service", "\ud83d\udccb  My Bookings", "\ud83d\udd14  Notifications", "\ud83d\udc64  My Profile"}, customer.getUserId());
        CardLayout cl = new CardLayout();
        JPanel content = new JPanel(cl);
        content.setBackground(BG);
        content.add(this.buildCustomerOverview(customer), "OVERVIEW");
        content.add(this.buildBookServiceScreen(customer, cl, content), "BOOK");
        content.add(this.buildCustomerBookings(customer), "BOOKINGS");
        content.add(this.buildNotificationPanel(customer.getUserId()), "NOTIF");
        content.add(this.buildProfile(customer), "PROFILE");
        cl.show(content, "OVERVIEW");
        JButton[] navBtns = (JButton[])sidebar.getClientProperty("navBtns");
        String[] screens = new String[]{"OVERVIEW", "BOOK", "BOOKINGS", "NOTIF", "PROFILE"};

        for(int i = 0; i < navBtns.length - 1; ++i) {
            String screen = screens[i];
            navBtns[i].addActionListener((e) -> {
                if (screen.equals("BOOKINGS")) {
                    content.remove(content.getComponent(2));
                    content.add(this.buildCustomerBookings(customer), "BOOKINGS", 2);
                }

                if (screen.equals("OVERVIEW")) {
                    content.remove(content.getComponent(0));
                    content.add(this.buildCustomerOverview(customer), "OVERVIEW", 0);
                }

                if (screen.equals("NOTIF")) {
                    content.remove(content.getComponent(3));
                    content.add(this.buildNotificationPanel(customer.getUserId()), "NOTIF", 3);
                    this.nm.markAllRead(customer.getUserId());
                }

                cl.show(content, screen);
                this.highlightNav(navBtns, i);
            });
        }

        navBtns[navBtns.length - 1].addActionListener((e) -> {
            this.currentUser = null;
            this.cardLayout.show(this.mainPanel, "LOGIN");
        });
        root.add(sidebar, "West");
        root.add(content, "Center");
        return root;
    }

    JPanel buildCustomerOverview(Customer customer) {
        JPanel panel = new JPanel();
        panel.setLayout(new BoxLayout(panel, 1));
        panel.setBackground(BG);
        panel.setBorder(new EmptyBorder(30, 30, 30, 30));
        JLabel greeting = label("Good day, " + customer.getName() + "! \ud83d\udc4b", 24, true, TEXT_DARK);
        JLabel sub = label("Here's what's happening with your services", 14, false, TEXT_MUTED);
        greeting.setAlignmentX(0.0F);
        sub.setAlignmentX(0.0F);
        JPanel statsRow = new JPanel(new GridLayout(1, 3, 16, 0));
        statsRow.setBackground(BG);
        statsRow.setAlignmentX(0.0F);
        statsRow.setMaximumSize(new Dimension(Integer.MAX_VALUE, 120));
        int total = customer.getBookingHistory().size();
        int active = customer.getActiveBookings().size();
        int completed = (int)customer.getBookingHistory().stream().filter((b) -> b.getStatus().equals("Completed")).count();
        statsRow.add(this.statCard("Total Bookings", String.valueOf(total), new Color(239, 246, 255), PRIMARY));
        statsRow.add(this.statCard("Active Bookings", String.valueOf(active), new Color(240, 253, 244), SUCCESS));
        statsRow.add(this.statCard("Completed", String.valueOf(completed), new Color(250, 245, 255), new Color(126, 34, 206)));
        JLabel recTitle = label("Recent Bookings", 17, true, TEXT_DARK);
        recTitle.setAlignmentX(0.0F);
        JPanel bookList = new JPanel();
        bookList.setLayout(new BoxLayout(bookList, 1));
        bookList.setBackground(BG);
        bookList.setAlignmentX(0.0F);
        List<Booking> history = customer.getBookingHistory();
        if (history.isEmpty()) {
            JLabel empty = label("No bookings yet. Go to 'Book Service' to get started!", 14, false, TEXT_MUTED);
            empty.setAlignmentX(0.0F);
            bookList.add(empty);
        } else {
            for(int i = Math.max(0, history.size() - 3); i < history.size(); ++i) {
                bookList.add(this.bookingRow((Booking)history.get(i)));
                bookList.add(Box.createVerticalStrut(8));
            }
        }

        panel.add(greeting);
        panel.add(Box.createVerticalStrut(4));
        panel.add(sub);
        panel.add(Box.createVerticalStrut(24));
        panel.add(statsRow);
        panel.add(Box.createVerticalStrut(28));
        panel.add(recTitle);
        panel.add(Box.createVerticalStrut(12));
        panel.add(bookList);
        return panel;
    }

    JPanel buildBookServiceScreen(Customer customer, CardLayout parentCL, JPanel parentPanel) {
        JPanel panel = new JPanel(new BorderLayout(0, 0));
        panel.setBackground(BG);
        List<Service> allSvcs = this.db.getServices();
        int globalMin = 0;
        int globalMax = 5000;
        if (!allSvcs.isEmpty()) {
            globalMin = (int)allSvcs.stream().mapToDouble(Service::getPrice).min().orElse((double)0.0F);
            globalMax = (int)allSvcs.stream().mapToDouble(Service::getPrice).max().orElse((double)5000.0F);
        }

        int[] priceRange = new int[]{globalMin, globalMax};
        int[] minRating = new int[]{0};
        JPanel header = new JPanel();
        header.setLayout(new BoxLayout(header, 1));
        header.setBackground(CARD_BG);
        header.setBorder(BorderFactory.createCompoundBorder(new MatteBorder(0, 0, 1, 0, BORDER), new EmptyBorder(16, 24, 12, 24)));
        JPanel row1 = new JPanel(new FlowLayout(0, 10, 0));
        row1.setBackground(CARD_BG);
        row1.setMaximumSize(new Dimension(Integer.MAX_VALUE, 44));
        row1.setAlignmentX(0.0F);
        JLabel pageTitle = label("Book a Service", 20, true, TEXT_DARK);
        JTextField searchField = styledField("Search by name or description...", 18);
        searchField.setPreferredSize(new Dimension(240, 36));
        searchField.setMaximumSize(new Dimension(240, 36));
        String[] cats = new String[]{"All Categories", "Plumbing", "Electrical", "Cleaning", "AC Repair"};
        JComboBox<String> catBox = new JComboBox(cats);
        catBox.setFont(new Font("Segoe UI", 0, 13));
        catBox.setPreferredSize(new Dimension(160, 36));
        String[] sortOpts = new String[]{"Sort: Default", "Price: Low to High", "Price: High to Low", "Rating: Best First", "Duration: Shortest"};
        JComboBox<String> sortBox = new JComboBox(sortOpts);
        sortBox.setFont(new Font("Segoe UI", 0, 13));
        sortBox.setPreferredSize(new Dimension(180, 36));
        JLabel resultsLbl = label("", 12, false, TEXT_MUTED);
        row1.add(pageTitle);
        row1.add(Box.createHorizontalStrut(16));
        row1.add(searchField);
