package homeservicessystem;

public class Service {
    private String serviceId;
    private String name;
    private String category;
    private double price;
    private int durationMinutes;
    private String description;
    private String providerId;

    public Service(String serviceId, String name, String category, double price, int durationMinutes, String description, String providerId) {
        this.serviceId = serviceId;
        this.name = name;
        this.category = category;
        this.price = price;
        this.durationMinutes = durationMinutes;
        this.description = description;
        this.providerId = providerId;
    }

    public String getServiceId() {
        return this.serviceId;
    }

    public String getName() {
        return this.name;
    }

    public void setName(String name) {
        this.name = name;
    }

    public String getCategory() {
        return this.category;
    }

    public void setCategory(String category) {
        this.category = category;
    }

    public double getPrice() {
        return this.price;
    }

    public void setPrice(double price) {
        this.price = price;
    }

    public int getDurationMinutes() {
        return this.durationMinutes;
    }

    public void setDurationMinutes(int durationMinutes) {
        this.durationMinutes = durationMinutes;
    }

    public String getDescription() {
        return this.description;
    }

    public void setDescription(String description) {
        this.description = description;
    }

    public String getProviderId() {
        return this.providerId;
    }

    public String getFormattedPrice() {
        return String.format("PKR %.0f", this.price);
    }

    public String getFormattedDuration() {
        if (this.durationMinutes < 60) {
            return this.durationMinutes + " min";
        } else {
            int var10000 = this.durationMinutes / 60;
            return var10000 + "h " + this.durationMinutes % 60 + "min";
        }
    }

    public String toString() {
        String var10000 = this.name;
        return var10000 + " - " + this.getFormattedPrice();
    }
}
